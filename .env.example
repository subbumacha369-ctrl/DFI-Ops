# ─── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used by admin/service operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for OAuth redirects & email links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Anthropic (AI pipeline — used from Phase 6 onward) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key
# Model tiering
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# ─── Upstash Redis (rate limiting + queue) ───────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Email (transactional — wired in Phase 4) ───────────────────────────────
RESEND_API_KEY=re_your_key
EMAIL_FROM="Operations OS <noreply@yourdomain.com>"
